# -------------------------------------------------------------------
# Frontend (Vite) environment — copy this file to `.env` and fill in.
#   cp .env.example .env
#
# IMPORTANT:
#  * Use the ANON / public key ONLY — it starts with "eyJ...".
#    Find it in Supabase Dashboard -> Settings -> API -> "Project API keys"
#    -> `anon` `public`.
#  * NEVER put the `service_role` key or an `sbp_...` access token here.
#    They would be embedded in the public site's JavaScript and give
#    anyone full control of your project.
#  * The URL is the base project URL WITHOUT any path.
#    Right:  https://YOUR-REF.supabase.co
#    Wrong:  https://YOUR-REF.supabase.co/rest/v1/
# -------------------------------------------------------------------

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PASTE_YOUR_ANON_JWT_HERE
